    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/js-cookie": "3.0.6",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
