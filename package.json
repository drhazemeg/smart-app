  "imports": {
    "#/*": "./src/*"
  },
  "keywords": [
    "tanstack-intent"
  ],
  "name": "smart-clinic",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "private": true,
  "scripts": {
    "add-ui-components": "bunx --bun shadcn@latest add ",
    "auth:generate": "bunx @better-auth/cli generate --config ./src/lib/auth/auth.ts --output ./src/lib/db/schema/auth.ts",
    "build": "vite build",
    "check": "biome check --write",
    "check:fix": "biome check --write",
    "db:clean": "psql $DATABASE_URL -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:neon-setup": "bunx neondb",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:reset": "rm -rf ./drizzle && bun run db:clean && bun x drizzle-kit generate && bun x drizzle-kit migrate",
    "db:seed": "bun run ./src/db/seed/index.ts",
    "db:setup-vector": "bun --env-file=.env run ./scripts/setup-vector-extension.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "bun --env-file=.env run vite dev --port 3000",
    "email:dev": "email dev --dir src/components/emails --port 5555",
    "format": "biome format --write",
    "gen": "bun generate ",
    "generate": "bunx @tanstack/router-cli generate ",
    "generate-routes": "tsr generate",
    "intent:install": "bunx  @tanstack/intent@latest install",
    "intent:list": "bunx  @tanstack/intent@latest list",
    "intent:load": "bunx  @tanstack/intent@latest load",
    "intent:scaffold": "bunx  @tanstack/intent@latest scaffold",
    "intent:stale": "bunx  @tanstack/intent@latest stale",
    "intent:validate": "bunx  @tanstack/intent@latest validate",
    "lint": "biome lint --write",
    "preview": "vite preview",
    "refresh": "rimraf node_modules .tanstack migrations src/generated && bun install && bun db:reset && bun generate && bun paraglide",
    "start": "node .output/server/index.mjs",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "npx tsc --noEmit --skipLibCheck --pretty",
    "ui": "bunx --bun shadcn@latest add"
  },
  "type": "module"
}
